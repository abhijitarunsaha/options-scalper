# ── Kite Connect ─────────────────────────────────────────────────────────────
KITE_API_KEY=XXXXX
KITE_API_SECRET=XXXXX
KITE_ACCESS_TOKEN=XXXXX
KITE_REQUEST_TOKEN=XXXXX

# ── Index: NIFTY | BANKNIFTY | SENSEX ────────────────────────────────────────
DEFAULT_INDEX=NIFTY

# ── Lot sizes (NSE current) ───────────────────────────────────────────────────
NIFTY_LOT_SIZE=65
BANKNIFTY_LOT_SIZE=30
SENSEX_LOT_SIZE=20

# ── Budget ────────────────────────────────────────────────────────────────────
BUDGET_PER_LOT=1000

# ── Signal thresholds ─────────────────────────────────────────────────────────
# STRONG signal: fires on confirmed trend + structure alignment
SIGNAL_THRESHOLD_STRONG=7
# MODERATE signal: fires when trend is clear, some structure
SIGNAL_THRESHOLD_MODERATE=5
# SCOUT signal: fires on pure trend-following (trending market only)
SIGNAL_THRESHOLD_SCOUT=3

# Minimum candles before any signal
MIN_CANDLES=10

# ── Market hours (HH:MM IST 24h) ─────────────────────────────────────────────
MARKET_OPEN=09:15
SIGNAL_START=09:15
SIGNAL_END=15:20
MARKET_CLOSE=15:30

# ── Risk management ───────────────────────────────────────────────────────────
SL_LIMIT_PCT=20
TRAILING_SL_PCT=5
TAKE_PROFIT_PCT=95
MIN_TARGET_GAP=5

# ── Trend detection (multi-timeframe EMA periods) ────────────────────────────
TREND_EMA_FAST=9
TREND_EMA_SLOW=21
TREND_EMA_LONG=50
